   "source": [
    "gap_cols = [col for col in df.columns if '_Gap' in col]\n",
    "\n",
    "for col in gap_cols:\n",
    "    df[f'{col}_Lag1'] = df.groupby('REF_AREA_LABEL')[col].shift(1)\n",
    "\n",
    "# Handle NaNs created by lagging (first year of each country)\n",
    "df = df.groupby('REF_AREA_LABEL').apply(lambda x: x.ffill().bfill()).reset_index(drop=True)\n",
    "\n",
    "# Drop original level features, keeping only metadata, gaps, and lagged gaps\n",
    "metadata = ['REF_AREA', 'REF_AREA_LABEL', 'TIME_PERIOD', 'target_credit_gap2']\n",
    "lag_cols = [f'{col}_Lag1' for col in gap_cols]\n",
    "df = df[metadata + gap_cols + lag_cols]\n",
    "\n",
    "df.head()"
    df.drop(columns=['is_crisis_now'], inplace=True)
    # -------------------------------

    # Drop original level features, keeping only metadata, gaps, and lagged gaps
    metadata = ['REF_AREA', 'REF_AREA_LABEL', 'TIME_PERIOD', 'target_credit_gap2']
    lag_cols = [f'{col}_Lag1' for col in gap_cols]
    crisis_cols = ['total_crisis_count', 'years_since_last_crisis', 'crisis_freq_10y', 'was_crisis_last_year']
    df = df[metadata + gap_cols + lag_cols + crisis_cols]\n",
    "\n",
    "df.head()"
   ]
  },
