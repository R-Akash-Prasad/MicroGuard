   ],
   "source": [
    "indicators = df.columns.difference(['REF_AREA', 'REF_AREA_LABEL', 'TIME_PERIOD'])\n",
    "lamb = 100\n",
    "\n",
    "for col in indicators:\n",
    "    def get_gap(group):\n",
    "        # hpfilter returns (cycle, trend)\n",
    "        cycle, _ = hpfilter(group, lamb=lamb)\n",
    "        return cycle\n",
    "    \n",
    "    df[f'{col}_Gap'] = df.groupby('REF_AREA_LABEL')[col].transform(get_gap)\n",
    "\n",
    "print(\"Gaps calculated for all indicators.\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "17478782",
   "metadata": {},
   "source": [
    "### **Target Variable Creation**\n",
    "Our goal is to predict the 'Credit-to-GDP Gap' (specifically banking credit) two years into the future."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e3374c78",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Data shape after target creation and dropna: (1240, 22)\n"
     ]
    }
   ],
   "source": [
    "credit_col = 'Domestic credit to private sector by banks (% of GDP)_Gap'\n",
    "\n",
    "# Shift the gap 2 years forward for prediction\n",
    "df['target_credit_gap2'] = df.groupby('REF_AREA_LABEL')[credit_col].shift(-2)\n",
    "\n",
    "# Drop rows where we don't have a target (the last two years per country)\n",
    "df = df.dropna(subset=['target_credit_gap2'])\n",
    "\n",
    "# Capping (Winsorization) for target variable to handle extreme outliers\n",
    "lower_limit = df['target_credit_gap2'].quantile(0.01)\n",
    "upper_limit = df['target_credit_gap2'].quantile(0.99)\n",
    "df['target_credit_gap2'] = df['target_credit_gap2'].clip(lower_limit, upper_limit)\n",
    "\n",
    "print(f\"Target variable capped between {lower_limit:.4f} and {upper_limit:.4f}\")\n",
    "print(f\"Data shape after target creation and dropna: {df.shape}\")"
   ]
  },
