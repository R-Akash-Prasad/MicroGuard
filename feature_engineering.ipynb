  {
   "cell_type": "markdown",
   "id": "66eddb56",
   "metadata": {},
   "source": [
    "### **Visualizing the HP Filter & Gaps**\n",
    "Visualizing how the HP Filter decomposes our data into Trend and Cycle (Gap)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "e834bc12",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "def plot_hp_decomposition(country, indicator):\n",
    "    # Reload raw data for clean visualization\n",
    "    raw_df = pd.read_csv('final_data.csv')\n",
    "    raw_country_data = raw_df[raw_df['REF_AREA_LABEL'] == country].sort_values('TIME_PERIOD')\n",
    "    raw_series = raw_country_data[indicator]\n",
    "    \n",
    "    cycle, trend = hpfilter(raw_series, lamb=100)\n",
    "    \n",
    "    plt.figure(figsize=(12, 6))\n",
    "    \n",
    "    # Subplot 1: Actual vs Trend\n",
    "    plt.subplot(2, 1, 1)\n",
    "    plt.plot(raw_country_data['TIME_PERIOD'], raw_series, label='Actual', color='blue')\n",
    "    plt.plot(raw_country_data['TIME_PERIOD'], trend, label='Trend (HP Filter)', color='red', linestyle='--')\n",
    "    plt.title(f'HP Decomposition: {indicator} ({country})')\n",
    "    plt.legend()\n",
    "    \n",
    "    # Subplot 2: Cycle (Gap)\n",
    "    plt.subplot(2, 1, 2)\n",
    "    plt.fill_between(raw_country_data['TIME_PERIOD'], cycle, 0, where=(cycle >= 0), color='green', alpha=0.3, label='Positive Gap (Bubble)')\n",
    "    plt.fill_between(raw_country_data['TIME_PERIOD'], cycle, 0, where=(cycle < 0), color='red', alpha=0.3, label='Negative Gap')\n",
    "    plt.axhline(0, color='black', linestyle='-', linewidth=1)\n",
    "    plt.ylabel('Cycle (Gap)')\n",
    "    plt.legend()\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Example visualization\n",
    "plot_hp_decomposition('India', 'Domestic credit to private sector by banks (% of GDP)')"
   ]
  },
